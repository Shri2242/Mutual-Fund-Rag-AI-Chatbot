# ─────────────────────────────────────────────────────────────────────────────
# Mutual Fund FAQ Assistant — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API Key (required for LLM answer generation)
# Get yours free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use (default: llama3-8b-8192)
# Other options: llama3-70b-8192, mixtral-8x7b-32768, gemma-7b-it
GROQ_MODEL=llama3-8b-8192

# Generation settings
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=256
